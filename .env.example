# Firebase/Node Environment Configuration
# Copy this to .env and fill in your values

# Server Settings
PORT=3000

# MongoDB Connection String
# Get this from MongoDB Atlas (free tier available)
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sha-enrollment?retryWrites=true&w=majority

# Node Environment
NODE_ENV=production
